PROJECT=swag
ENV=local
COMPOSE_PROJECT_NAME=${PROJECT}${ENV}
HOST=${ENV}-${PROJECT}.on.stack.lol # resolves to: local-swag.on.stack.lol
HTTP_ROUTER_ENTRYPOINT=websecure
HTTP_ROUTER_ENTRYPOINT=web,websecure

# PROXY
PROXY_HOST=proxy-192-168-1-58-${HOST}

# API
API_HOST=api-192-168-1-58-${HOST}
API_AUTH_SECRET=swagsecret

# API REST
APIREST_HOST=apirest-192-168-1-58-${HOST}

# APP
APP_HOST=${HOST}
APP_NAME=${PROJECT}
GRAPHQL_API_ENDPOINT=https://${API_HOST}/graphql

# DB
DB_USERNAME=${PROJECT}
DB_PASSWORD=password
DB_DATABASE=${PROJECT}
DB_SCHEMA=${PROJECT}
DB_PORT=35432
DB_CONNECTION_STRING=postgres://${DB_USERNAME}:${DB_PASSWORD}@db/${DB_DATABASE}?sslmode=disable
DB_JWT_SECRET=${API_AUTH_SECRET}

# ADMIN
ADMIN_HOST=admin-192-168-1-58-${HOST}
ADMIN_AUTH_USER=swag
ADMIN_AUTH_PASS=swag

# ADMINER
ADMINER_HOST=adminer-192-168-1-58-${HOST}

# WORKER
WEBAPP_URL=http://${APIREST_HOST}
WORKER_CRON=true
WORKER_CRON_JOB_ECHO_SWAG_SCHEDULE="@every 1m"
CRON_SLACK_WEBHOOK=

# STATUS
STATUS_HOST=status-192-168-1-58-${HOST}
